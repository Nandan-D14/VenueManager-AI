# ==========================================
# VenueManager-AI — Root .gitignore
# ==========================================

# ------ SECRETS (NEVER commit these) ------
.env
.env.*
*.env
!.env.example

# ------ Python Backend ------
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/**/*.pyc
backend/*.pyo
backend/*.pyd
backend/.Python
backend/dist/
backend/build/
backend/*.egg-info/
backend/.pytest_cache/

# ------ Node / Frontend ------
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ------ OS & Editor ------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ------ Logs ------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
